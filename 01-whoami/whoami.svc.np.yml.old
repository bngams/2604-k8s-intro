apiVersion: v1
kind: Service
metadata:
  name: whoami-np
  namespace: whoami
spec:
  selector:
    app.kubernetes.io/name: whoami
  type: NodePort
  ports:
  - port: 80 # port d'exposition du service
    protocol: TCP
    targetPort: 80 # port du container ciblé
    nodePort: 30080 # port d'exposition sur les nœuds du cluster
